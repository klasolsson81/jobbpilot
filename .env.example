# ======================================================================
# JobbPilot — lokal utveckling (mall)
# ======================================================================
#
# Kopiera denna fil till .env i repo-roten och fyll i starka värden.
#   $ cp .env.example .env
#
# .env är gitignored. Committa aldrig verkliga lösenord.
# Dev-lösenord skyddar enbart localhost-portar, men håll dem starka
# som vana (pwnable docker-setup kan bli angreppsbrygga).
#
# Generera starka värden:
#   Windows PowerShell:
#     -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 32 | ForEach-Object {[char]$_})
#   bash/WSL:
#     openssl rand -hex 16

# -----------------------------------------------------------------------
# PostgreSQL — dev + test (separata instanser, separata portar)
# -----------------------------------------------------------------------
POSTGRES_PASSWORD_DEV=change-me
POSTGRES_PASSWORD_TEST=change-me

# -----------------------------------------------------------------------
# Redis — auth avstängd lokalt; lämnas tom i dev.
# Aktivera när vi börjar testa auth-flöden.
# -----------------------------------------------------------------------
REDIS_PASSWORD_DEV=
