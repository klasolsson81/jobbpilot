{
  // STEG 12 prod-overlay (TD-21 / TD-17). ConnectionStrings injiceras via env-vars
  // från ECS task-definition + AWS Secrets Manager — committas INTE här.

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  // KnownNetworks populeras med ALB:s VPC-CIDR i STEG 13 efter VPC-skapande. Tom
  // array = ASP.NET-default (loopback only) → IP-baserad rate-limiting blir
  // effektivt no-op bakom ALB. PRE-LAUNCH-GATE per docs/runbooks/aws-setup.md §3.3
  // — Api/Program.cs throwar fail-loud om miljö != Development/Test och denna lista
  // är tom (Sec-Major-1 production-defense, STEG 12).
  //
  // ForwardLimit: ALB-only-deploy = 1. Höj till 2 ENBART om CloudFront introduceras
  // FRAMFÖR ALB — och då måste KnownProxies ALSO populeras med CloudFront-prefix-list
  // (com.amazonaws.global.cloudfront.origin-facing). Annars stoppar ASP.NET vid
  // första untrusted-hop och RemoteIpAddress blir CloudFront-IP, inte klient-IP =
  // ForwardLimit=1-effekt utan att märkas. Se aws-setup.md §3.3 för uppdaterings-
  // procedur när CloudFront införs.
  "ForwardedHeaders": {
    "KnownNetworks": [],
    "KnownProxies": [],
    "ForwardLimit": 1
  },

  // HSTS — aktiveras tillsammans med Alb:HttpsEnabled (synkron flip vid
  // ADR 0026-trigger 1). Header sätts bara på HTTPS-svar; så länge
  // HttpsEnabled=false är detta block ren konfig utan effekt.
  //
  // Preload=false initialt — submit till hstspreload.org är prod-launch-step,
  // inte Fas 0. Oåterkalleligt på kort sikt (browsern hardcodar).
  "Hsts": {
    "MaxAgeDays": 365,
    "IncludeSubDomains": true,
    "Preload": false
  }
}
