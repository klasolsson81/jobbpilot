<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>JobbPilot.Migrate</RootNamespace>
    <AssemblyName>JobbPilot.Migrate</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <!-- Postgres connection + DDL execution -->
    <PackageReference Include="Npgsql" />
    <!-- Hangfire-schema-installer (officiell DDL-väg per docs/runbooks/hangfire-schema.md) -->
    <PackageReference Include="Hangfire.PostgreSql" />
    <!-- AWS Secrets Manager för read master-secret + write app/worker connection-strings -->
    <PackageReference Include="AWSSDK.SecretsManager" />
    <!-- Logging till stdout → CloudWatch -->
    <PackageReference Include="Microsoft.Extensions.Logging.Console" />
  </ItemGroup>

</Project>
