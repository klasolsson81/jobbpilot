<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\JobbPilot.Application\JobbPilot.Application.csproj" />
    <ProjectReference Include="..\JobbPilot.Domain\JobbPilot.Domain.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="EFCore.NamingConventions" />
    <PackageReference Include="Microsoft.EntityFrameworkCore" />
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" />
    <PackageReference Include="Microsoft.AspNetCore.Identity.EntityFrameworkCore" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" />
    <PackageReference Include="StackExchange.Redis" />
    <PackageReference Include="Microsoft.Extensions.Caching.StackExchangeRedis" />
    <PackageReference Include="AWSSDK.KeyManagementService" />
    <PackageReference Include="Refit" />
    <PackageReference Include="Refit.HttpClientFactory" />
    <PackageReference Include="Microsoft.Extensions.Http.Resilience" />
  </ItemGroup>

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <!-- ADR 0043 — committad off-search-path taxonomi-snapshot (Variant A).
         Embedded så seedern läser den deterministiskt utan fil-deploy. -->
    <EmbeddedResource Include="Taxonomy\taxonomy-snapshot.json">
      <LogicalName>JobbPilot.Infrastructure.Taxonomy.taxonomy-snapshot.json</LogicalName>
    </EmbeddedResource>
    <!-- ADR 0067 Fas C2 — FRUSEN migration-ägd reverse-lookup-resurs
         (occupation-name → ssyk-level-4). Läses ENDAST av C2-migrationen;
         regenereras aldrig (CTO-dom (c) 2026-06-09, migrations-immutabilitet). -->
    <EmbeddedResource Include="Persistence\Migrations\Resources\occupation-name-to-ssyk-level-4.v30.json">
      <LogicalName>JobbPilot.Infrastructure.Persistence.Migrations.Resources.occupation-name-to-ssyk-level-4.v30.json</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="JobbPilot.Application.UnitTests" />
    <InternalsVisibleTo Include="JobbPilot.Api.IntegrationTests" />
    <!-- TD-13 C2 Seam 3: ScopedUserDataKeyCache internal zeroing-observerbarhet -->
    <InternalsVisibleTo Include="JobbPilot.Worker.IntegrationTests" />
  </ItemGroup>

</Project>
