{
  // STEG 12 prod-overlay (TD-17). ConnectionStrings (Postgres + HangfireStorage)
  // injiceras via env-vars från ECS task-definition + AWS Secrets Manager
  // (jobbliggaren/prod/postgres-app, jobbliggaren/prod/postgres-worker). Värden committas
  // INTE i overlay. Se docs/runbooks/hangfire-schema.md §4 för GRANT-modell.

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },

  // PrepareSchemaIfNecessary=false i prod. Schema-DDL körs via runbook §3
  // (Install.sql) som jobbliggaren_migrations innan första Worker-deploy. Worker-
  // runtime-rollen jobbliggaren_worker har INTE CREATE-rättigheter. Production-
  // defense i Worker/Program.cs throwar om denna flagga är true utanför
  // Development/Test (TD-17 punkt 1).
  "Hangfire": {
    "PrepareSchemaIfNecessary": false,
    "ShutdownTimeoutSeconds": 25
  }
}
