#!/usr/bin/env sh

set -e

echo "[pre-push] Kör gates..."

# Gitleaks: scaffold-agnostisk, alltid aktiv.
# Fallback-lookup för Windows/WinGet-installation där PATH kan missa i hook-context.
GITLEAKS_BIN=""
if command -v gitleaks >/dev/null 2>&1; then
    GITLEAKS_BIN="gitleaks"
elif command -v gitleaks.exe >/dev/null 2>&1; then
    GITLEAKS_BIN="gitleaks.exe"
else
    # Sök i WinGet-standardplats (Windows)
    WINGET_GITLEAKS=$(ls "$HOME/AppData/Local/Microsoft/WinGet/Packages/"Gitleaks.Gitleaks_*/gitleaks.exe 2>/dev/null | head -1)
    if [ -n "$WINGET_GITLEAKS" ] && [ -x "$WINGET_GITLEAKS" ]; then
        GITLEAKS_BIN="$WINGET_GITLEAKS"
    fi
fi

if [ -n "$GITLEAKS_BIN" ]; then
    echo "[pre-push] Gitleaks scan..."
    "$GITLEAKS_BIN" detect --source . --no-banner --redact || {
        echo "✗ Gitleaks fann potentiella secrets. Granska innan push." >&2
        echo "  Om false positive: lägg till i .gitleaksignore med kommentar." >&2
        exit 1
    }
else
    echo "✗ gitleaks hittades inte i PATH eller standard WinGet-sökväg." >&2
    echo "  Installera via 'winget install gitleaks.gitleaks' eller fixa PATH." >&2
    echo "  BLOCKERAR PUSH — secret-scan är obligatorisk på publikt repo." >&2
    exit 1
fi

# Scaffold-gate för tester
SLN=$(find . -maxdepth 2 -name "*.sln" 2>/dev/null | head -1)
WEB_DIR="web/jobbpilot-web"

if [ -z "$SLN" ] && [ ! -d "$WEB_DIR" ]; then
    echo "[pre-push] Inget scaffold än — hoppar över full test-suite."
    echo "[pre-push] När Fas 0/1 lägger till projekt: uppdatera .husky/pre-push per SESSION-2-PLAN §4.9."
    exit 0
fi

# .NET full suite (aktiveras i Fas 0/1)
if [ -n "$SLN" ]; then
    echo "[pre-push] .NET full suite + integration..."
    # dotnet test --no-build --verbosity minimal || exit 1
    echo "[pre-push] (.NET test-raderna är kommenterade tills test-projekt finns — se §4.9)"
fi

# Web full suite (aktiveras i Fas 0/1)
if [ -d "$WEB_DIR" ]; then
    echo "[pre-push] Web full suite..."
    # (cd "$WEB_DIR" && pnpm test) || exit 1
    echo "[pre-push] (Web test-raderna är kommenterade tills test-projekt finns)"
fi

echo "[pre-push] ✓ Alla pre-push-gates passerade."
exit 0
