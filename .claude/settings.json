{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "model": "claude-sonnet-4-6",
  "effortLevel": "high",
  "defaultShell": "bash",
  "respectGitignore": true,
  "autoMemoryDirectory": ".claude/auto-memory",

  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/session-start.sh", "timeout": 10000 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/guard-spec-files.sh", "timeout": 5000 }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/guard-bash.sh", "timeout": 5000 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/post-cs-edit.sh", "timeout": 30000 },
          { "type": "command", "command": "bash .claude/hooks/post-ts-edit.sh", "timeout": 30000 }
        ]
      },
      {
        "matcher": "TodoWrite",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/post-todo-review.sh", "timeout": 5000 }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/pre-compact-save.sh", "timeout": 15000 }
        ]
      }
    ]
  },

  "permissions": {
    "defaultMode": "default",

    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "TodoWrite",
      "WebSearch",

      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:platform.claude.com)",
      "WebFetch(domain:www.anthropic.com)",
      "WebFetch(domain:nuget.org)",
      "WebFetch(domain:www.nuget.org)",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:docs.aws.amazon.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:jobsearch.api.jobtechdev.se)",
      "WebFetch(domain:taxonomy.api.jobtechdev.se)",
      "WebFetch(domain:api.scb.se)",

      "Bash(dotnet build:*)",
      "Bash(dotnet test:*)",
      "Bash(dotnet run:*)",
      "Bash(dotnet restore:*)",
      "Bash(dotnet format:*)",
      "Bash(dotnet ef migrations:*)",
      "Bash(dotnet new:*)",
      "Bash(dotnet sln:*)",
      "Bash(dotnet add:*)",
      "Bash(dotnet list package:*)",
      "Bash(dotnet --version)",
      "Bash(dotnet --info)",

      "Bash(pnpm:*)",
      "Bash(npx:*)",
      "Bash(corepack:*)",
      "Bash(node --version)",

      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git pull:*)",
      "Bash(git stash:*)",
      "Bash(git fetch:*)",
      "Bash(git ls-files:*)",
      "Bash(git check-ignore:*)",

      "Bash(docker:*)",
      "Bash(docker compose:*)",

      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(which:*)",
      "Bash(jq:*)",
      "Bash(openssl rand:*)",

      "Bash(gh auth status:*)",
      "Bash(gh repo:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh api:*)",
      "Bash(gh label:*)",
      "Bash(gh release view:*)",
      "Bash(gh workflow:*)",

      "Bash(aws sts get-caller-identity:*)",
      "Bash(aws sso login:*)",
      "Bash(aws configure:*)",
      "Bash(aws s3api:*)",
      "Bash(aws s3 ls:*)",
      "Bash(aws dynamodb describe-table:*)",
      "Bash(aws dynamodb list-tables:*)",
      "Bash(aws budgets describe-budgets:*)",
      "Bash(aws budgets describe-notifications-for-budget:*)",
      "Bash(aws cloudtrail describe-trails:*)",
      "Bash(aws cloudtrail lookup-events:*)",
      "Bash(aws kms list-aliases:*)",
      "Bash(aws kms list-keys:*)",
      "Bash(aws kms describe-key:*)",
      "Bash(aws secretsmanager list-secrets:*)",
      "Bash(aws secretsmanager describe-secret:*)",
      "Bash(aws iam list-policies:*)",
      "Bash(aws iam get-policy:*)",
      "Bash(aws iam list-attached-role-policies:*)",
      "Bash(aws iam list-users:*)",
      "Bash(aws bedrock list-foundation-models:*)",
      "Bash(aws bedrock list-inference-profiles:*)",
      "Bash(aws bedrock get-foundation-model:*)",
      "Bash(aws bedrock get-foundation-model-availability:*)",
      "Bash(aws bedrock get-inference-profile:*)",

      "Bash(terraform init:*)",
      "Bash(terraform validate:*)",
      "Bash(terraform fmt:*)",
      "Bash(terraform plan:*)",
      "Bash(terraform output:*)",
      "Bash(terraform show:*)",
      "Bash(terraform state list:*)",
      "Bash(terraform state show:*)",
      "Bash(terraform -version)",

      "Bash(gitleaks detect:*)",
      "Bash(gitleaks version)",

      "Agent(Explore)",
      "Agent(Plan)",
      "Agent(general-purpose)",

      "Skill(*)"
    ],

    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf $HOME*)",
      "Bash(sudo *)",
      "Bash(chmod 777*)",
      "Bash(curl * | bash*)",
      "Bash(curl * | sh*)",
      "Bash(wget * | bash*)",
      "Bash(wget * | sh*)",
      "Bash(dd if=*)",

      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard origin/*)",
      "Bash(git clean -fd*)",

      "Bash(dotnet ef database drop*)",

      "Bash(terraform destroy*)",

      "Bash(aws * delete-*)",
      "Bash(aws * delete --*)",
      "Bash(aws iam delete-user*)",
      "Bash(aws iam delete-access-key*)",
      "Bash(aws s3 rb *)",
      "Bash(aws s3 rm * --recursive*)",
      "Bash(aws kms schedule-key-deletion*)",
      "Bash(aws kms disable-key*)"
    ],

    "ask": [
      "Write(BUILD.md)",
      "Edit(BUILD.md)",
      "Write(CLAUDE.md)",
      "Edit(CLAUDE.md)",
      "Write(DESIGN.md)",
      "Edit(DESIGN.md)",
      "Bash(git push:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(terraform apply*)",
      "Bash(dotnet ef database update*)"
    ]
  }
}
